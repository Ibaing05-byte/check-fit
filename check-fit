    var(--paper);
  color: var(--ink);
}

button,
input,
select {
  font: inherit;
}

button {
  min-height: 46px;
  border: 0;
  border-radius: 8px;
  padding: 12px 16px;
  background: var(--ink);
  color: white;
  font-weight: 800;
  cursor: pointer;
  transition: transform 160ms ease, opacity 160ms ease, background 160ms ease;
}

button:hover {
  transform: translateY(-1px);
}

button:disabled {
  cursor: not-allowed;
  opacity: 0.45;
  transform: none;
}

label {
  display: grid;
  gap: 7px;
  color: var(--muted);
  font-size: 13px;
  font-weight: 750;
}

input,
select {
  width: 100%;
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 12px 13px;
  background: #fbfaf8;
  color: var(--ink);
  outline: none;
}

input:focus,
select:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(185, 63, 50, 0.14);
}

.app-shell {
  width: min(1240px, calc(100% - 32px));
  margin: 0 auto;
  padding: 24px 0 40px;
}

.hero {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 24px;
  align-items: end;
  min-height: 240px;
  margin-bottom: 18px;
  padding: 34px;
  border-radius: 8px;
  background:
    linear-gradient(rgba(23, 21, 20, 0.38), rgba(23, 21, 20, 0.78)),
    url("https://images.unsplash.com/photo-1496747611176-843222e1e57c?auto=format&fit=crop&w=1600&q=80") center 38% / cover;
  color: white;
  overflow: hidden;
  box-shadow: var(--shadow);
}

.hero h1 {
  margin: 0;
  font-size: clamp(46px, 7vw, 84px);
  line-height: 1;
  letter-spacing: 0;
}

.hero-copy {
  max-width: 650px;
  margin: 16px 0 0;
  color: rgba(255, 255, 255, 0.82);
  font-size: 18px;
  line-height: 1.55;
}

.hero-stats {
  display: grid;
  gap: 8px;
  min-width: 160px;
}

.hero-stats span {
  display: grid;
  gap: 2px;
  padding: 14px;
  border: 1px solid rgba(255, 255, 255, 0.28);
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(16px);
}

.hero-stats strong {
  font-size: 28px;
}

.layout {
  display: grid;
  grid-template-columns: 360px minmax(0, 1fr);
  gap: 18px;
  align-items: start;
}

.content-stack {
  display: grid;
  gap: 18px;
}

.panel {
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 22px;
  background: rgba(255, 255, 255, 0.86);
  box-shadow: var(--shadow);
}

.closet-actions {
  position: sticky;
  top: 18px;
}

.section-heading {
  margin-bottom: 16px;
}

.section-heading h2,
.result h3 {
  margin: 0;
  font-size: 24px;
  letter-spacing: 0;
}

.section-heading.compact {
  margin-top: 4px;
}

.section-heading.inline {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: center;
}

.eyebrow {
  margin: 0 0 6px;
  color: var(--accent);
  font-size: 12px;
  font-weight: 900;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.eyebrow.dark {
  color: var(--accent-dark);
}

.form-stack {
  display: grid;
  gap: 12px;
}

.mode-switch {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6px;
  padding: 5px;
  margin-bottom: 16px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: #f1ece4;
}

.mode-button {
  min-height: 40px;
  padding: 9px 10px;
  border: 1px solid transparent;
  background: transparent;
  color: var(--muted);
}

.mode-button.active {
  background: var(--ink);
  color: white;
  box-shadow: 0 8px 20px rgba(23, 21, 20, 0.14);
}

.mode-panel {
  display: none;
}

.mode-panel.active {
  display: grid;
}

.mode-copy {
  margin: 0 0 12px;
  color: var(--muted);
  font-size: 14px;
  line-height: 1.45;
}

.field-grid,
.controls-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.closet-actions .field-grid {
  grid-template-columns: 1fr;
}

.upload-box {
  position: relative;
  display: grid;
  gap: 4px;
  min-height: 96px;
  place-items: center;
  padding: 18px;
  border: 1px dashed rgba(23, 21, 20, 0.34);
  border-radius: 8px;
  background: linear-gradient(135deg, rgba(216, 231, 239, 0.72), rgba(255, 255, 255, 0.88));
  color: var(--ink);
  text-align: center;
  cursor: pointer;
}

.upload-box span {
  font-size: 15px;
  font-weight: 900;
}

.upload-box small {
  color: var(--muted);
  font-weight: 650;
}

.upload-box input {
  position: absolute;
  width: 1px;
  height: 1px;
  opacity: 0;
  pointer-events: none;
}

.upload-box.scan {
  background: linear-gradient(135deg, rgba(116, 134, 111, 0.16), rgba(255, 255, 255, 0.92));
}

.preview {
  display: none;
  width: 100%;
  aspect-ratio: 4 / 3;
  object-fit: cover;
  border-radius: 8px;
  border: 1px solid var(--line);
  background: #ece8e0;
}

.auto-hint {
  margin: 0;
  padding: 10px 12px;
  border: 1px solid rgba(116, 134, 111, 0.28);
  border-radius: 8px;
  background: rgba(116, 134, 111, 0.1);
  color: #4f604b;
  font-size: 13px;
  line-height: 1.45;
}

.auto-hint[hidden] {
  display: none;
}

.divider {
  height: 1px;
  margin: 22px 0;
  background: var(--line);
}

.closet-preview-wrap {
  position: relative;
  overflow: hidden;
  margin: 12px 0;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: #ede9e2;
}

.closet-preview-wrap[hidden] {
  display: none;
}

.closet-preview {
  display: block;
  width: 100%;
  max-height: 360px;
  object-fit: cover;
}

.scan-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.scan-overlay span {
  position: absolute;
  border: 2px solid rgba(255, 255, 255, 0.86);
  border-radius: 8px;
  box-shadow: 0 0 0 1px rgba(23, 21, 20, 0.32), 0 14px 34px rgba(23, 21, 20, 0.2);
}

.scan-overlay span:nth-child(1) {
  left: 10%;
  top: 18%;
  width: 30%;
  height: 42%;
}

.scan-overlay span:nth-child(2) {
  right: 12%;
  top: 16%;
  width: 28%;
  height: 48%;
}

.scan-overlay span:nth-child(3) {
  left: 34%;
  bottom: 10%;
  width: 26%;
  height: 28%;
}

.scan-flow {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  margin: 12px 0;
}

.scan-flow span {
  min-height: 42px;
  display: grid;
  place-items: center;
  padding: 8px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: #fbfaf8;
  color: var(--muted);
  font-size: 12px;
  font-weight: 850;
  text-align: center;
}

.scan-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-top: 12px;
}

.secondary {
  background: var(--sage);
}

.ghost {
  border: 1px solid var(--line);
  background: transparent;
  color: var(--ink);
}

.danger {
  color: var(--accent-dark);
}

.note {
  margin: 0;
  color: var(--muted);
  font-size: 13px;
  line-height: 1.45;
}

.badge {
  min-width: 34px;
  padding: 6px 10px;
  border-radius: 8px;
  background: var(--ink);
  color: white;
  text-align: center;
  font-weight: 900;
}

.result {
  display: grid;
  gap: 16px;
  margin-top: 16px;
  padding: 18px;
  border-radius: 8px;
  background: #f1ece4;
}

.result[hidden] {
  display: none;
}

.result p {
  margin: 0;
  color: #544f4a;
  line-height: 1.55;
}

.outfit-grid,
.wardrobe,
.pending-gallery {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  gap: 14px;
}

.wardrobe:empty::before,
.pending-gallery:empty::before {
  content: "Todavía no hay prendas aquí.";
  grid-column: 1 / -1;
  padding: 24px;
  border: 1px dashed var(--line);
  border-radius: 8px;
  color: var(--muted);
  text-align: center;
}

.item,
.pending-card,
.outfit-piece {
  overflow: hidden;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: white;
}

.item img,
.pending-card img,
.outfit-piece img {
  display: block;
  width: 100%;
  aspect-ratio: 4 / 3;
  object-fit: cover;
  background: #ede9e2;
}

.item-body,
.outfit-piece div {
  display: grid;
  gap: 6px;
  padding: 13px;
}

.item-top {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 34px;
  gap: 12px;
  align-items: start;
}

.item-top > div {
  min-width: 0;
}

.item strong,
.outfit-piece strong {
  display: block;
  color: var(--ink);
  font-size: 15px;
  overflow-wrap: anywhere;
}

.item small,
.outfit-piece small {
  display: block;
  color: var(--muted);
  line-height: 1.4;
}

.delete {
  flex: 0 0 auto;
  width: 34px;
  min-height: 34px;
  padding: 0;
  border-radius: 8px;
  background: #f1ece4;
  color: var(--accent-dark);
}

.pending-card {
  display: grid;
}

.pending-fields {
  display: grid;
  gap: 10px;
  padding: 13px;
}

.pending-fields .field-grid {
  grid-template-columns: 1fr;
}

.pending-actions {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 10px;
}

.pending-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 14px;
}

.pending-footer button {
  width: min(220px, 100%);
}

@media (max-width: 920px) {
  .layout {
    grid-template-columns: 1fr;
  }

  .closet-actions {
    position: static;
  }
}

@media (max-width: 680px) {
  .app-shell {
    width: min(100% - 20px, 1240px);
    padding-top: 10px;
  }

  .hero {
    grid-template-columns: 1fr;
    min-height: 300px;
    padding: 24px;
  }

  .hero-stats {
    grid-template-columns: 1fr 1fr;
  }

  .field-grid,
  .controls-grid,
  .scan-actions,
  .scan-flow {
    grid-template-columns: 1fr;
  }

  .panel {
    padding: 16px;
  }
}

